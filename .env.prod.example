# Production environment file. Copy to .env.prod on your server and fill in.
# DO NOT commit a filled-in version of this file.

# Domain you've pointed at the server
DOMAIN=example.com
PUBLIC_API_URL=https://example.com

# Postgres
POSTGRES_DB=crm
POSTGRES_USER=crm
POSTGRES_PASSWORD=__change_me__

# Auth
JWT_SECRET=__generate_a_long_random_string_at_least_32_chars__
WEBHOOK_API_KEY=__random_string_for_demo_or_remove__

# WhatsApp Cloud API (set MODE=real to enable)
WHATSAPP_MODE=stub
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# Telegram
TELEGRAM_MODE=stub
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenAI
OPENAI_MODE=stub
OPENAI_API_KEY=

# Email (SMTP)
EMAIL_MODE=stub
EMAIL_FROM=no-reply@example.com
EMAIL_OWNER=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Google Sheets export
SHEETS_MODE=stub
SHEETS_SPREADSHEET_ID=
SHEETS_RANGE=Sheet1!A:H
SHEETS_CREDENTIALS_JSON=
