# Production environment file. Copy to .env.prod on your server and fill in.
# DO NOT commit a filled-in version of this file.

# Domain you've pointed at the server
DOMAIN=example.com
PUBLIC_API_URL=https://example.com

# Postgres
POSTGRES_DB=crm
POSTGRES_USER=crm
POSTGRES_PASSWORD=__change_me__

# Auth
JWT_SECRET=__generate_a_long_random_string_at_least_32_chars__
WEBHOOK_API_KEY=__random_string_for_demo_or_remove__
# Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY=__base64_encoded_32_bytes__

# Anti-abuse
LOGIN_MAX_FAILED=5
LOGIN_LOCK_MINUTES=15
LOGIN_RPM=10
EMAIL_VERIFICATION_REQUIRED=true
EMAIL_VERIFICATION_TTL_HOURS=48

# Monitoring (Prometheus + Grafana on :3001)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=__change_me__
GRAFANA_ROOT_URL=https://grafana.example.com

# Nightly DB backups to S3 (or any S3-compatible store: B2, R2, MinIO, etc.)
BACKUP_S3_BUCKET=my-crm-backups
BACKUP_S3_PREFIX=crm/prod
BACKUP_S3_ENDPOINT_URL=
BACKUP_CRON=0 3 * * *
BACKUP_RETENTION_DAYS=30
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Error tracking (Sentry). Leave SENTRY_DSN blank to disable entirely.
# Create a project at https://sentry.io and paste the DSN from Project Settings → Client Keys.
# Use SEPARATE DSNs for the backend (Spring Boot project) and the frontend (Next.js project).
SENTRY_DSN=
SENTRY_ENVIRONMENT=prod
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=prod

# AI gateway. The router tries FAQ first, then the default provider.
# Set AI_DEFAULT_PROVIDER=openai only if you want every tenant on OpenAI by
# default; individual tenants can pin themselves to faq/ollama/openai in /settings.
AI_DEFAULT_PROVIDER=ollama
OLLAMA_ENABLED=true
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b

# Stripe Billing (optional). Leave BILLING_MODE=stub to skip Stripe entirely.
# To enable: create a Product+Price in Stripe Dashboard, then a webhook
# endpoint at https://yourdomain.com/webhooks/stripe.
BILLING_MODE=stub
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# WhatsApp Cloud API (set MODE=real to enable)
WHATSAPP_MODE=stub
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# Telegram
TELEGRAM_MODE=stub
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenAI
OPENAI_MODE=stub
OPENAI_API_KEY=

# Email (SMTP) — used for owner notifications AND signup verification.
# Amazon SES setup:
#   1. Verify your sending domain (or sender email) in SES console.
#   2. SMTP > Create SMTP credentials. Gives you SMTP_USER / SMTP_PASSWORD.
#   3. SMTP_HOST is region-specific, e.g. email-smtp.us-east-1.amazonaws.com
#   4. While in SES sandbox, EVERY recipient must also be verified.
EMAIL_MODE=real
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_OWNER=
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Google Sheets export
SHEETS_MODE=stub
SHEETS_SPREADSHEET_ID=
SHEETS_RANGE=Sheet1!A:H
SHEETS_CREDENTIALS_JSON=
