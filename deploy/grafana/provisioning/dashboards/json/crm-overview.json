{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "Codezilla CRM",
  "uid": "crm-overview",
  "tags": ["crm"],
  "panels": [
    {
      "type": "stat",
      "title": "JVM uptime (s)",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "process_uptime_seconds{job=\"crm-app\"}" }]
    },
    {
      "type": "stat",
      "title": "JVM memory used (MB)",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum(jvm_memory_used_bytes{job=\"crm-app\"}) / 1024 / 1024" }
      ]
    },
    {
      "type": "stat",
      "title": "Active HTTP requests",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(http_server_requests_active_seconds_count{job=\"crm-app\"})"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Hikari pool active",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "hikaricp_connections_active{job=\"crm-app\"}" }]
    },
    {
      "type": "timeseries",
      "title": "HTTP requests (rate per route)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{job=\"crm-app\"}[5m]))",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP latency p95 (s)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket{job=\"crm-app\"}[5m])))",
          "legendFormat": "p95 {{uri}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "5xx error rate",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{job=\"crm-app\",status=~\"5..\"}[5m]))",
          "legendFormat": "5xx {{uri}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM memory by area",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum by (area) (jvm_memory_used_bytes{job=\"crm-app\"})",
          "legendFormat": "{{area}}"
        }
      ]
    }
  ]
}
